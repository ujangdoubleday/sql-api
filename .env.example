# ─── Database ────────────────────────────────────────────────────────────────
# Supported drivers: mysql | postgres | sqlserver
DB_DRIVER=mysql

# MySQL:      user:password@tcp(host:3306)/dbname?parseTime=true
# PostgreSQL: postgres://user:password@host:5432/dbname?sslmode=disable
# SQL Server: sqlserver://user:password@host:1433?database=dbname
DB_DSN=root:secret@tcp(127.0.0.1:3306)/mydb?parseTime=true

# ─── Connection Pool ─────────────────────────────────────────────────────────
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ─── Query Execution ─────────────────────────────────────────────────────────
QUERY_TIMEOUT_SECONDS=10
